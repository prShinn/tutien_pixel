# .env — Copy file này thành .env và điền vào
# KHÔNG commit file .env lên git!

# Server
PORT=3000
NODE_ENV=development

# JWT Secret — THAY BẰNG CHUỖI RANDOM DÀI KHI PRODUCTION
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tu-tien-dev-secret-change-in-production

# Production DB (khi migrate từ lowdb sang PostgreSQL)
# DATABASE_URL=postgresql://user:pass@localhost:5432/tu_tien

# Production DB (MongoDB option)
# MONGO_URI=mongodb://localhost:27017/tu_tien

# CORS — domain frontend production
# CORS_ORIGIN=https://tu-tien-game.com
